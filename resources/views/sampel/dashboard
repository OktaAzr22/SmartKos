    // Form validation
    pengeluaranForm.addEventListener('submit', (e) => {
        const kategori = document.getElementById('kategori').value;
        const keterangan = document.getElementById('keterangan').value;
        const jumlah = document.getElementById('jumlah').value;
        const tanggal = document.getElementById('tanggal').value;
        
        let isValid = true;
        hideAllErrors();
        
        if (!kategori) {
            document.getElementById('error-kategori').classList.remove('hidden');
            isValid = false;
        }
        
        if (!keterangan) {
            document.getElementById('error-keterangan').classList.remove('hidden');
            isValid = false;
        }
        
        if (!jumlah) {
            document.getElementById('error-jumlah').classList.remove('hidden');
            isValid = false;
        }
        
        if (!tanggal) {
            document.getElementById('error-tanggal').classList.remove('hidden');
            isValid = false;
        }
        
        if (!isValid) {
            e.preventDefault();
            showAlert('Harap periksa kembali form Anda', 'error');
        }
    });

